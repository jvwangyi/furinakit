generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // bcrypt hashed password
  role          String    @default("user") // "user" or "admin"
  enabled       Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  history  ToolUsageHistory[]
  favorites Favorite[]
  academicProjects AcademicProject[]
  llmConfigs       LLMConfig[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ToolUsageHistory {
  id        String   @id @default(cuid())
  userId    String
  toolName  String
  usedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, usedAt])
  @@index([userId, toolName])
}

model Favorite {
  id       String   @id @default(cuid())
  userId   String
  toolName String
  addedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, toolName])
  @@index([userId])
}

model AcademicProject {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  topic       String?
  stage       String   @default("brainstorm")
  stageData   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  papers   AcademicPaper[]
  reviews  AcademicReview[]
  drafts   AcademicDraft[]

  @@index([userId])
}

model AcademicPaper {
  id           String  @id @default(cuid())
  projectId    String
  title        String
  authors      String?
  year         Int?
  abstract     String?
  url          String?
  doi          String?
  citationKey  String?
  addedAt      DateTime @default(now())

  project AcademicProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model AcademicReview {
  id        String   @id @default(cuid())
  projectId String
  stage     String   @default("literature_review")
  type      String   // "literature_review" | "peer_review" | "integrity_check" | "revision"
  content   String   // Markdown content
  config    String?  // JSON: { style, language, llm provider }
  score     Float?   // Review score (peer_review only)
  verdict   String?  // Accept / Minor Revision / Major Revision / Reject
  createdAt DateTime @default(now())

  project AcademicProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model AcademicDraft {
  id        String   @id @default(cuid())
  projectId String
  title     String
  content   String   // Markdown content
  version   Int      @default(1)
  createdAt DateTime @default(now())

  project AcademicProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model LLMConfig {
  id        String   @id @default(cuid())
  userId    String
  provider  String   // claude | openai | deepseek | mimo
  name      String   @default("Key 1")  // user-defined name for this key
  apiKey    String   // encrypted storage
  model     String?
  baseUrl   String?  // custom base URL override (e.g. Token Plan endpoint)
  saveMode  String   @default("session") // session | persistent
  isActive  Boolean  @default(true)       // whether this key is active
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, provider])
}
